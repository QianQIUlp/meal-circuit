# MEALCIRCUIT_AI_PROVIDER=openai
# MEALCIRCUIT_AI_MODEL=
# MEALCIRCUIT_OPENAI_API_KEY=
# MEALCIRCUIT_ANTHROPIC_API_KEY=
# MEALCIRCUIT_AI_TIMEOUT_SECONDS=120
# MEALCIRCUIT_AI_MAX_OUTPUT_TOKENS=8192
