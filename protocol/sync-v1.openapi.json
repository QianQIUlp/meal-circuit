            "minLength": 3,
            "title": "Login Name",
            "type": "string"
          },
          "password": {
            "maxLength": 512,
            "minLength": 12,
            "title": "Password",
            "type": "string"
          }
        },
        "required": [
          "login_name",
          "password",
          "device_name"
        ],
        "title": "AccountCreate",
        "type": "object"
      },
      "AckRequest": {
