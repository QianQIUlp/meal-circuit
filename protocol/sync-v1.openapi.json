          "cursor": {
            "minimum": 0.0,
            "title": "Cursor",
            "type": "integer"
          }
        },
        "required": [
          "cursor"
        ],
        "title": "AckRequest",
        "type": "object"
      },
      "BlobCreate": {
        "additionalProperties": false,
        "properties": {
          "blob_id": {
            "pattern": "^[0-9a-f]{64}$",
            "title": "Blob Id",
            "type": "string"
          },
          "byte_count": {
            "maximum": 1073741824.0,
            "minimum": 0.0,
            "title": "Byte Count",
            "type": "integer"
          },
          "chunk_count": {
            "maximum": 256.0,
            "minimum": 1.0,
            "title": "Chunk Count",
            "type": "integer"
          },
          "key_version": {
            "minimum": 1.0,
            "title": "Key Version",
            "type": "integer"
          }
        },
        "required": [
          "blob_id",
          "byte_count",
          "chunk_count",
          "key_version"
        ],
        "title": "BlobCreate",
        "type": "object"
      },
      "DeleteAccountRequest": {
        "additionalProperties": false,
        "properties": {
          "password": {
            "title": "Password",
            "type": "string"
          }
        },
        "required": [
          "password"
        ],
        "title": "DeleteAccountRequest",
        "type": "object"
      },
      "EnvelopeRequest": {
        "additionalProperties": false,
        "properties": {
          "envelope": {
            "additionalProperties": true,
            "title": "Envelope",
            "type": "object"
