        ],
        "title": "RotationCommit",
        "type": "object"
      },
      "SessionCreate": {
        "additionalProperties": false,
        "properties": {
          "device_name": {
            "maxLength": 160,
            "minLength": 1,
            "title": "Device Name",
            "type": "string"
          },
