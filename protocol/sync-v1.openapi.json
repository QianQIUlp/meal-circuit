        "additionalProperties": false,
        "properties": {
          "base_server_version": {
            "minimum": 0.0,
            "title": "Base Server Version",
            "type": "integer"
          },
          "envelope": {
            "additionalProperties": true,
            "title": "Envelope",
            "type": "object"
          },
          "key_version": {
            "minimum": 1.0,
            "title": "Key Version",
            "type": "integer"
          },
          "op_id": {
            "maxLength": 80,
            "minLength": 15,
            "title": "Op Id",
            "type": "string"
          },
